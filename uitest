	-- ─────────────────────────────────────────────────────────────────────────
	-- Méthode interne : gérer les tweens avec clé (évite les conflits)
	-- ─────────────────────────────────────────────────────────────────────────
	function win:_Tween(key, obj, info, props)
		if self._tweens[key] then
			self._tweens[key]:Cancel()
		end
		self._tweens[key] = Tween(obj, info, props)
		return self._tweens[key]
	end

	-- ─────────────────────────────────────────────────────────────────────────
	-- Draggable (corrigé : delta réel, supporte touch et souris)
	-- ─────────────────────────────────────────────────────────────────────────
	do
		local dragging = false
		local startFramePos, startInputPos

		local function onBegan(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				startFramePos = Main.Position
				startInputPos = Vector2.new(input.Position.X, input.Position.Y)
			end
		end

		local function onChanged(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
				or input.UserInputType == Enum.UserInputType.Touch) then
				local delta = Vector2.new(input.Position.X, input.Position.Y) - startInputPos
				Main.Position = UDim2.new(
					startFramePos.X.Scale,
					startFramePos.X.Offset + delta.X,
					startFramePos.Y.Scale,
					startFramePos.Y.Offset + delta.Y
				)
			end
		end

		local function onEnded(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end

		table.insert(win._conns, Header.InputBegan:Connect(onBegan))
		table.insert(win._conns, UserInputService.InputChanged:Connect(onChanged))
		table.insert(win._conns, UserInputService.InputEnded:Connect(onEnded))
	end

