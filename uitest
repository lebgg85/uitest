		PagePad.PaddingBottom = UDim.new(0, STYLE.Padding)
		PagePad.Parent = Page

		local PageList = Instance.new("UIListLayout")
		PageList.Padding = UDim.new(0, 8)
		PageList.SortOrder = Enum.SortOrder.LayoutOrder
		PageList.Parent = Page

		local function Activate()
			-- Désactive l'ancien tab
			if win.CurrentTab then
				local prev = win.CurrentTab
				Tween(prev.Button, STYLE.Fast, {
					BackgroundColor3 = STYLE.BG3,
					TextColor3 = STYLE.TextMuted,
				})
				Tween(prev.Indicator, STYLE.Fast, {Size = UDim2.new(0, 0, 0, 2)})
				prev.Page.Visible = false
			end
			-- Active ce tab
			Page.Visible = true
			Tween(TabButton, STYLE.Fast, {
				BackgroundColor3 = STYLE.BG4,
				TextColor3 = STYLE.White,
			})
			Tween(TabIndicator, STYLE.Fast, {Size = UDim2.new(0.8, 0, 0, 2)})
			win.TitleLabel.Text = name
			win.CurrentTab = {Page = Page, Button = TabButton, Indicator = TabIndicator}
		end

		table.insert(win._conns, TabButton.MouseButton1Click:Connect(Activate))

		-- Active automatiquement le premier tab
		if not win.CurrentTab then
			Activate()
		end

		-- ── Tab object ──────────────────────────────────────────────────────────
		local Tab = {}

		-- Helper : crée un Frame item de base
		local function BaseItem(h)
			local F = Instance.new("Frame")
			F.Size = UDim2.new(1, 0, 0, h or STYLE.ItemH)
			F.BackgroundColor3 = STYLE.BG2
			F.BorderSizePixel = 0
			F.Parent = Page
			Corner(F, STYLE.RadiusSmall)

			-- Hover subtil
			F.MouseEnter:Connect(function() Tween(F, STYLE.Fast, {BackgroundColor3 = STYLE.BG3}) end)
			F.MouseLeave:Connect(function() Tween(F, STYLE.Fast, {BackgroundColor3 = STYLE.BG2}) end)
			return F
		end

		local function ItemLabel(parent, text, xpad)
			return Label(parent, {Text = text, XPad = xpad or 14, Color = STYLE.White, Font = Enum.Font.Gotham})
		end

		-- ── Toggle ──────────────────────────────────────────────────────────────
		function Tab:AddToggle(name, default, callback)
			local F = BaseItem()
			ItemLabel(F, name, 14)

			local Switch = Instance.new("Frame")
			Switch.Size = UDim2.new(0, 58, 0, 30)
			Switch.Position = UDim2.new(1, -72, 0.5, -15)
			Switch.BackgroundColor3 = default and STYLE.Accent or STYLE.Off
			Switch.Parent = F
			Corner(Switch, STYLE.RadiusPill)

			local Knob = Instance.new("Frame")
			Knob.Size = UDim2.new(0, 24, 0, 24)
			Knob.Position = default
				and UDim2.new(1, -27, 0.5, -12)
				or  UDim2.new(0, 3, 0.5, -12)
			Knob.BackgroundColor3 = STYLE.White
			Knob.Parent = Switch
			Corner(Knob, STYLE.RadiusPill)

			local state = default or false

			local function UpdateSwitch()
				Tween(Switch, STYLE.Fast, {
					BackgroundColor3 = state and STYLE.Accent or STYLE.Off
				})
				Tween(Knob, STYLE.Fast, {
					Position = state
						and UDim2.new(1, -27, 0.5, -12)
						or  UDim2.new(0, 3, 0.5, -12)
				})
			end

			Switch.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
					or i.UserInputType == Enum.UserInputType.Touch then
					state = not state
					UpdateSwitch()
					if callback then callback(state) end
				end
			end)
			UpdateSwitch()

			return {
				Set = function(_, v)
					state = v
					UpdateSwitch()
					if callback then callback(state) end
				end,
				Get = function() return state end,
			}
		end

		-- ── Button ──────────────────────────────────────────────────────────────
		function Tab:AddButton(name, callback)
			local F = BaseItem(STYLE.ItemHSmall)
			F.BackgroundColor3 = STYLE.BG3
			Corner(F, STYLE.RadiusSmall)

			local Btn = Instance.new("TextButton")
