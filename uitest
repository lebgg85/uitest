		-- ── Slider ──────────────────────────────────────────────────────────────
		function Tab:AddSlider(name, opts, callback)
			opts = opts or {}
			local min    = opts.Min or 0
			local max    = opts.Max or 100
			local def    = opts.Default or min
			local suffix = opts.Suffix or ""

			local F = BaseItem(66)
			local value = math.clamp(def, min, max)

			local TopRow = Instance.new("Frame")
			TopRow.Size = UDim2.new(1, -28, 0, 28)
			TopRow.Position = UDim2.new(0, 14, 0, 8)
			TopRow.BackgroundTransparency = 1
			TopRow.Parent = F

			Label(TopRow, {Text = name, Color = STYLE.White, Font = Enum.Font.Gotham})

			local ValLabel = Label(TopRow, {
				Text = tostring(value) .. suffix,
				Color = STYLE.Accent,
				Font = Enum.Font.GothamBold,
				XAlign = Enum.TextXAlignment.Right,
			})

			local Track = Instance.new("Frame")
			Track.Size = UDim2.new(1, -28, 0, 6)
			Track.Position = UDim2.new(0, 14, 0, 44)
			Track.BackgroundColor3 = STYLE.BG4
			Track.BorderSizePixel = 0
			Track.Parent = F
			Corner(Track, STYLE.RadiusPill)

			local Fill = Instance.new("Frame")
			Fill.Size = UDim2.new((value - min)/(max - min), 0, 1, 0)
			Fill.BackgroundColor3 = STYLE.Accent
			Fill.BorderSizePixel = 0
			Fill.Parent = Track
			Corner(Fill, STYLE.RadiusPill)

			local Thumb = Instance.new("Frame")
			Thumb.Size = UDim2.new(0, 16, 0, 16)
			Thumb.Position = UDim2.new((value - min)/(max - min), -8, 0.5, -8)
			Thumb.BackgroundColor3 = STYLE.White
			Thumb.Parent = Track
			Corner(Thumb, STYLE.RadiusPill)

			local dragging = false

			local function SetValue(v)
				value = math.clamp(math.round(v), min, max)
				local pct = (value - min) / (max - min)
				ValLabel.Text = tostring(value) .. suffix
				Tween(Fill, STYLE.Fast, {Size = UDim2.new(pct, 0, 1, 0)})
				Tween(Thumb, STYLE.Fast, {Position = UDim2.new(pct, -8, 0.5, -8)})
				if callback then callback(value) end
			end

			local function CalcFromInput(input)
				local rx = Track.AbsolutePosition.X
				local rw = Track.AbsoluteSize.X
				local pct = math.clamp((input.Position.X - rx) / rw, 0, 1)
				SetValue(min + pct * (max - min))
			end

			Track.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
					or i.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					CalcFromInput(i)
				end
			end)

			local moveConn = UserInputService.InputChanged:Connect(function(i)
				if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement
					or i.UserInputType == Enum.UserInputType.Touch) then
					CalcFromInput(i)
				end
			end)
			local endConn = UserInputService.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
					or i.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)
			table.insert(win._conns, moveConn)
			table.insert(win._conns, endConn)

			return {
				Set = function(_, v) SetValue(v) end,
				Get = function() return value end,
			}
		end

		-- ── Dropdown ────────────────────────────────────────────────────────────
		function Tab:AddDropdown(name, options, default, callback)
			local F = BaseItem()
			ItemLabel(F, name, 14)

			local selected = default or (options and options[1]) or ""

			local DropBtn = Instance.new("TextButton")
			DropBtn.Size = UDim2.new(0, 130, 0, 32)
			DropBtn.Position = UDim2.new(1, -144, 0.5, -16)
			DropBtn.BackgroundColor3 = STYLE.BG4
			DropBtn.Text = selected
			DropBtn.TextColor3 = STYLE.White
			DropBtn.Font = Enum.Font.Gotham
			DropBtn.TextSize = 13
			DropBtn.AutoButtonColor = false
			DropBtn.Parent = F
			Corner(DropBtn, UDim.new(0, 8))

			local Arrow = Label(DropBtn, {
				Text = "▾",
				Size = UDim2.new(0, 20, 1, 0),
				Position = UDim2.new(1, -22, 0, 0),
				Color = STYLE.TextMuted,
				Font = Enum.Font.GothamBold,
			})

			-- Liste déroulante (Frame absolu au-dessus du Content)
			local ListFrame = Instance.new("Frame")
			ListFrame.Size = UDim2.new(0, 130, 0, 0)
			ListFrame.BackgroundColor3 = STYLE.BG3
			ListFrame.BorderSizePixel = 0
			ListFrame.Visible = false
			ListFrame.ZIndex = 5
			ListFrame.Parent = ScreenGui
			Corner(ListFrame, UDim.new(0, 10))
			Stroke(ListFrame, STYLE.BG4, 1)

			local Scrolling = Instance.new("ScrollingFrame")
			Scrolling.Size = UDim2.new(1, 0, 1, 0)
			Scrolling.BackgroundTransparency = 1
			Scrolling.ScrollBarThickness = 3
			Scrolling.ScrollBarImageColor3 = STYLE.Accent
			Scrolling.Parent = ListFrame

			local LL = Instance.new("UIListLayout")
			LL.Padding = UDim.new(0, 2)
			LL.SortOrder = Enum.SortOrder.LayoutOrder
			LL.Parent = Scrolling

			local LPad = Instance.new("UIPadding")
			LPad.PaddingLeft = UDim.new(0, 4)
			LPad.PaddingRight = UDim.new(0, 4)
			LPad.PaddingTop = UDim.new(0, 4)
			LPad.PaddingBottom = UDim.new(0, 4)
			LPad.Parent = Scrolling

			local open = false

			local function PositionList()
				local abs = DropBtn.AbsolutePosition
				local absSize = DropBtn.AbsoluteSize
				ListFrame.Position = UDim2.new(0, abs.X, 0, abs.Y + absSize.Y + 4)
			end

			local function CloseList()
				open = false
				Arrow.Text = "▾"
				Tween(ListFrame, STYLE.Fast, {Size = UDim2.new(0, 130, 0, 0)})
				task.wait(0.22)
				ListFrame.Visible = false
			end

			DropBtn.MouseButton1Click:Connect(function()
				open = not open
				if open then
					PositionList()
					local h = math.min(#options * 36 + 8, 200)
					ListFrame.Visible = true
					ListFrame.Size = UDim2.new(0, 130, 0, 0)
					Arrow.Text = "▴"
					Tween(ListFrame, STYLE.Med, {Size = UDim2.new(0, 130, 0, h)})
					Scrolling.CanvasSize = UDim2.new(0, 0, 0, #options * 36 + 8)
				else
					CloseList()
				end
			end)

			for _, opt in ipairs(options or {}) do
				local Opt = Instance.new("TextButton")
				Opt.Size = UDim2.new(1, 0, 0, 34)
				Opt.BackgroundColor3 = STYLE.BG3
				Opt.Text = opt
				Opt.TextColor3 = opt == selected and STYLE.Accent or STYLE.White
				Opt.Font = Enum.Font.Gotham
				Opt.TextSize = 13
				Opt.AutoButtonColor = false
				Opt.Parent = Scrolling
				Corner(Opt, UDim.new(0, 6))

				Opt.MouseEnter:Connect(function() Tween(Opt, STYLE.Fast, {BackgroundColor3 = STYLE.BG4}) end)
				Opt.MouseLeave:Connect(function() Tween(Opt, STYLE.Fast, {BackgroundColor3 = STYLE.BG3}) end)

				Opt.MouseButton1Click:Connect(function()
					selected = opt
					DropBtn.Text = opt
					for _, child in ipairs(Scrolling:GetChildren()) do
						if child:IsA("TextButton") then
							child.TextColor3 = child.Text == opt and STYLE.Accent or STYLE.White
						end
					end
					CloseList()
					if callback then callback(opt) end
				end)
			end

			return {
				Set = function(_, v)
					selected = v
					DropBtn.Text = v
				end,
				Get = function() return selected end,
			}
		end

		-- ── TextBox ─────────────────────────────────────────────────────────────
		function Tab:AddTextBox(name, opts, callback)
			opts = opts or {}
			local placeholder = opts.Placeholder or "Texte..."
			local default     = opts.Default or ""
			local numeric     = opts.Numeric or false

			local F = BaseItem(58)
			local value = default

			local TopRow = Instance.new("Frame")
			TopRow.Size = UDim2.new(1, -28, 0, 22)
			TopRow.Position = UDim2.new(0, 14, 0, 6)
			TopRow.BackgroundTransparency = 1
			TopRow.Parent = F
			Label(TopRow, {Text = name, Color = STYLE.TextMuted, Font = Enum.Font.Gotham, TextScaled = false})
			TopRow.FindFirstChild("TextLabel").TextSize = 12

			local InputFrame = Instance.new("Frame")
			InputFrame.Size = UDim2.new(1, -28, 0, 26)
			InputFrame.Position = UDim2.new(0, 14, 0, 28)
			InputFrame.BackgroundColor3 = STYLE.BG4
			InputFrame.BorderSizePixel = 0
			InputFrame.Parent = F
			Corner(InputFrame, UDim.new(0, 6))

			local Input = Instance.new("TextBox")
			Input.Size = UDim2.new(1, -12, 1, 0)
			Input.Position = UDim2.new(0, 6, 0, 0)
			Input.BackgroundTransparency = 1
			Input.Text = default
			Input.PlaceholderText = placeholder
			Input.PlaceholderColor3 = STYLE.TextDim
			Input.TextColor3 = STYLE.White
			Input.Font = Enum.Font.Gotham
			Input.TextSize = 13
			Input.TextXAlignment = Enum.TextXAlignment.Left
			Input.ClearTextOnFocus = false
			if numeric then Input.InputType = Enum.InputType.Number end
			Input.Parent = InputFrame

			Input.Focused:Connect(function()
				Tween(InputFrame, STYLE.Fast, {BackgroundColor3 = STYLE.BG3})
				Stroke(InputFrame, STYLE.Accent, 1.5)
			end)
			Input.FocusLost:Connect(function(enter)
				value = Input.Text
				Tween(InputFrame, STYLE.Fast, {BackgroundColor3 = STYLE.BG4})
				local s = InputFrame:FindFirstChildOfClass("UIStroke")
				if s then s:Destroy() end
				if callback then callback(value, enter) end
			end)

			return {
				Set = function(_, v) Input.Text = v; value = v end,
				Get = function() return value end,
			}
		end

		-- ── Keybind ─────────────────────────────────────────────────────────────
		function Tab:AddKeybind(name, default, callback)
			local F = BaseItem()
			ItemLabel(F, name, 14)

			local current = default or Enum.KeyCode.Unknown
			local listening = false

			local KeyBtn = Instance.new("TextButton")
			KeyBtn.Size = UDim2.new(0, 90, 0, 30)
			KeyBtn.Position = UDim2.new(1, -104, 0.5, -15)
			KeyBtn.BackgroundColor3 = STYLE.BG4
			KeyBtn.Text = current == Enum.KeyCode.Unknown and "Aucun" or current.Name
			KeyBtn.TextColor3 = STYLE.White
			KeyBtn.Font = Enum.Font.GothamBold
			KeyBtn.TextSize = 12
			KeyBtn.AutoButtonColor = false
			KeyBtn.Parent = F
			Corner(KeyBtn, UDim.new(0, 8))

			KeyBtn.MouseButton1Click:Connect(function()
				listening = true
				KeyBtn.Text = "..."
				KeyBtn.TextColor3 = STYLE.Accent
				Tween(KeyBtn, STYLE.Fast, {BackgroundColor3 = STYLE.BG3})
			end)

			local inputConn
			inputConn = UserInputService.InputBegan:Connect(function(input, gpe)
				if not listening then return end
				if input.UserInputType == Enum.UserInputType.Keyboard then
					listening = false
					current = input.KeyCode
					KeyBtn.Text = current.Name
					KeyBtn.TextColor3 = STYLE.White
					Tween(KeyBtn, STYLE.Fast, {BackgroundColor3 = STYLE.BG4})
					if callback then callback(current) end
				end
			end)
			table.insert(win._conns, inputConn)

			return {
				Set = function(_, k) current = k; KeyBtn.Text = k.Name end,
				Get = function() return current end,
			}
		end

		-- ── Label (info statique) ────────────────────────────────────────────────
		function Tab:AddLabel(text)
			local F = Instance.new("Frame")
			F.Size = UDim2.new(1, 0, 0, 36)
			F.BackgroundTransparency = 1
			F.Parent = Page

			Label(F, {
				Text = text,
				Color = STYLE.TextMuted,
				Font = Enum.Font.Gotham,
				XPad = 4,
			})
		end

		table.insert(win._tabs, Tab)
		return Tab
	end

	return win
end

return AquaPulse
